# VoicePrint — Environment Variables
# Copy this file to .env and fill in your API keys.
# Only the variables for your chosen provider need to be set.

# Google Gemini (Free) — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Groq (Free) — https://console.groq.com/keys
# GROQ_API_KEY=

# Mistral (Free) — https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# OpenCode Zen — https://opencode.ai
# OPENCODE_API_KEY=

# Override LLM model (optional)
# VOICEPRINT_LLM_MODEL=

# Override similarity threshold (optional, default 0.68)
# VOICEPRINT_SIMILARITY_THRESHOLD=0.68
