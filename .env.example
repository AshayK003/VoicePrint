# VoicePrint Environment Variables
# Copy this to .env and fill in your keys

# LLM Provider (default: gemini/gemini-2.0-flash — free tier)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative providers (uncomment one)
# OPENAI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=

# Optional overrides
# VOICEPRINT_LLM_MODEL=gemini/gemini-2.0-flash
# VOICEPRINT_SIMILARITY_THRESHOLD=0.78
